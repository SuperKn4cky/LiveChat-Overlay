{
  "name": "livechat",
  "version": "1.0.13",
  "main": "main.js",
  "description": "LiveChat Desktop App",
  "author": "Babz",
  "packageManager": "traversal@1.0.0",
  "scripts": {
    "prestart": "npm run build",
    "start": "electron .",
    "lint": "eslint . --max-warnings=0",
    "check:lines": "./scripts/check-max-lines.sh",
    "typecheck": "tsc -p tsconfig.main.json --noEmit && tsc -p tsconfig.preload.json --noEmit && tsc -p tsconfig.renderer.json --noEmit",
    "build:main": "tsc -p tsconfig.main.json",
    "build:preload": "tsc -p tsconfig.preload.json",
    "build:renderer": "tsc -p tsconfig.renderer.json",
    "build": "npm run build:main && npm run build:preload && npm run build:renderer",
    "check:renderer:esm": "node ./scripts/assert-renderer-esm.mjs",
    "verify:renderer:esm": "npm run build:renderer && npm run check:renderer:esm",
    "test:unit": "node --test tests/main/*.test.js",
    "test:unit:build": "npm run build:main && npm run build:preload && npm run test:unit",
    "package": "npm run build && electron-builder",
    "package:win": "npm run build && electron-builder --win nsis portable",
    "package:win:setup": "npm run build && electron-builder --win nsis",
    "package:win:portable": "npm run build && electron-builder --win portable",
    "verify:win:artifacts": "node ./scripts/assert-win-artifacts.mjs",
    "verify:win:local": "npm run package:win -- --publish never && npm run verify:win:artifacts",
    "dist": "npm run package",
    "verify": "./scripts/verify.sh"
  },
  "build": {
    "appId": "com.livechat",
    "productName": "LiveChat",
    "files": [
      "main.js",
      "main.runtime.js",
      "preload.js",
      "protocol.js",
      "dist/main/**/*",
      "dist/preload/**/*",
      "dist/renderer/**/*",
      "dist/shared/**/*",
      "renderer/**/*",
      "icon.png",
      "icon.ico",
      "package.json"
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "icon.ico"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "allowToChangeInstallationDirectory": false,
      "artifactName": "LiveChat-Setup-${version}.${ext}"
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.utilities",
      "identity": "-"
    },
    "dmg": {
      "artifactName": "LiveChat-macOS-${arch}.${ext}"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "SuperKn4cky",
        "repo": "LiveChat-Overlay",
        "releaseType": "release"
      }
    ]
  },
  "dependencies": {
    "electron-updater": "^6.8.3",
    "socket.io-client": "^4.8.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.0",
    "@types/node": "^24.6.0",
    "electron": "^39.2.7",
    "electron-builder": "^26.8.1",
    "eslint": "^9.39.0",
    "globals": "^16.4.0",
    "prettier": "^3.6.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.46.0"
  },
  "overrides": {
    "minimatch": "^10.2.2"
  }
}
